---
/**
 * GraphControls - Search, preset selector, genre chips, and edge type toggles
 */

interface Preset {
  id: string;
  name: string;
  description: string;
  genres: string[];
  dateRange: { start: number; end: number } | null;
  featured: string[];
}

interface Props {
  presets: {
    presets: Preset[];
    genreGroups: Record<string, string[]>;
  };
}

const { presets } = Astro.props;
const presetsJSON = JSON.stringify(presets);
---

<div class="graph-controls" id="graph-controls">
  <!-- Search -->
  <div class="search-container">
    <input
      type="text"
      id="graph-search"
      placeholder="Search artists..."
      autocomplete="off"
      class="search-input"
    />
    <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
    <ul class="search-results" id="search-results"></ul>
  </div>

  <!-- Preset selector -->
  <div class="preset-container">
    <select id="graph-preset" class="preset-select">
      <option value="">All Artists</option>
      {presets.presets.map(p => (
        <option value={p.id}>{p.name}</option>
      ))}
      <option value="custom">Custom Filter...</option>
    </select>
    <p class="preset-description" id="preset-description"></p>
  </div>

  <!-- Edge type toggles (shown when preset active) -->
  <div class="edge-type-toggles" id="edge-type-toggles">
    <button class="edge-toggle-btn active" data-type="collaborator" title="Toggle collaborator edges">
      <span class="dot collaborator"></span>Collabs
    </button>
    <button class="edge-toggle-btn active" data-type="influenced" title="Toggle influence edges">
      <span class="dot influenced"></span>Influence
    </button>
    <button class="edge-toggle-btn active" data-type="mentor" title="Toggle mentor edges">
      <span class="dot mentor"></span>Mentors
    </button>
  </div>

  <!-- Stats display -->
  <div class="graph-stats" id="graph-stats">
    <span class="stat-item">
      <span class="stat-value" id="node-count">0</span>
      <span class="stat-label">artists</span>
    </span>
    <span class="stat-divider">|</span>
    <span class="stat-item">
      <span class="stat-value" id="edge-count">0</span>
      <span class="stat-label">connections</span>
    </span>
  </div>

  <!-- Genre chips panel (shown when "Custom" selected) -->
  <div class="genre-panel" id="genre-panel">
    {Object.entries(presets.genreGroups).map(([group, genres]) => (
      <div class="genre-group">
        <span class="group-label">{group}</span>
        <div class="genre-chips">
          {genres.map(g => (
            <button class="genre-chip" data-genre={g}>{g}</button>
          ))}
        </div>
      </div>
    ))}
    <div class="genre-actions">
      <button class="genre-action-btn" id="clear-genres">Clear All</button>
    </div>
  </div>
</div>

<script define:vars={{ presetsJSON }}>
  window.__graphPresets = JSON.parse(presetsJSON);
</script>

<script>
  const presetSelect = document.getElementById('graph-preset');
  const presetDesc = document.getElementById('preset-description');
  const genrePanel = document.getElementById('genre-panel');
  const edgeToggles = document.getElementById('edge-type-toggles');
  const presets = window.__graphPresets;

  // Active genre set for custom mode
  let activeGenres = new Set();
  let activePresetId = '';

  // Preset selection
  presetSelect?.addEventListener('change', (e) => {
    const value = e.target.value;
    activePresetId = value;

    if (value === 'custom') {
      genrePanel?.classList.add('active');
      presetDesc.textContent = 'Select genres to filter';
      edgeToggles?.classList.add('active');
      // Don't dispatch filter yet — wait for genre chip clicks
    } else if (value === '') {
      genrePanel?.classList.remove('active');
      presetDesc.textContent = '';
      edgeToggles?.classList.remove('active');
      activeGenres.clear();
      updateChipStates();
      // Clear filter
      window.dispatchEvent(new CustomEvent('graph:filterChanged', {
        detail: { genres: null, dateRange: null, presetId: null }
      }));
    } else {
      genrePanel?.classList.remove('active');
      const preset = presets.presets.find(p => p.id === value);
      if (preset) {
        presetDesc.textContent = preset.description;
        activeGenres = new Set(preset.genres);
        updateChipStates();
        edgeToggles?.classList.add('active');
        window.dispatchEvent(new CustomEvent('graph:filterChanged', {
          detail: { genres: preset.genres, dateRange: preset.dateRange, presetId: preset.id }
        }));
      }
    }
  });

  // Genre chip clicks
  document.querySelectorAll('.genre-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const genre = chip.dataset.genre;
      if (activeGenres.has(genre)) {
        activeGenres.delete(genre);
        chip.classList.remove('active');
      } else {
        activeGenres.add(genre);
        chip.classList.add('active');
      }

      if (activeGenres.size > 0) {
        window.dispatchEvent(new CustomEvent('graph:filterChanged', {
          detail: { genres: Array.from(activeGenres), dateRange: null, presetId: 'custom' }
        }));
      } else {
        window.dispatchEvent(new CustomEvent('graph:filterChanged', {
          detail: { genres: null, dateRange: null, presetId: null }
        }));
      }
    });
  });

  // Clear all genres
  document.getElementById('clear-genres')?.addEventListener('click', () => {
    activeGenres.clear();
    updateChipStates();
    window.dispatchEvent(new CustomEvent('graph:filterChanged', {
      detail: { genres: null, dateRange: null, presetId: null }
    }));
  });

  function updateChipStates() {
    document.querySelectorAll('.genre-chip').forEach(chip => {
      chip.classList.toggle('active', activeGenres.has(chip.dataset.genre));
    });
  }

  // Edge type toggles
  document.querySelectorAll('.edge-toggle-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.classList.toggle('active');
      const type = btn.dataset.type;
      const visible = btn.classList.contains('active');
      window.dispatchEvent(new CustomEvent('graph:settingsChanged', {
        detail: { key: 'edgeVisibility', value: { type, visible } }
      }));
    });
  });
</script>

<style>
  .graph-controls {
    position: absolute;
    top: 4rem;
    left: 1rem;
    z-index: 100;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 300px;
  }

  .search-container {
    position: relative;
  }

  .search-input {
    width: 100%;
    padding: 0.625rem 0.875rem 0.625rem 2.5rem;
    font-size: 0.875rem;
    background: var(--color-bg-content);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    outline: none;
    transition: border-color var(--duration-fast), box-shadow var(--duration-fast);
  }

  .search-input:focus {
    border-color: var(--electric-cyan);
    box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.15);
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  .search-icon {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1rem;
    height: 1rem;
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .search-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 0.25rem;
    padding: 0;
    list-style: none;
    background: var(--color-bg-content);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    max-height: 240px;
    overflow-y: auto;
    display: none;
  }

  .search-results.active {
    display: block;
  }

  .search-results li {
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--color-text);
    transition: background var(--duration-fast);
  }

  .search-results li:hover,
  .search-results li.selected {
    background: var(--color-accent-light);
  }

  .search-results li .connections-count {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-left: 0.5rem;
  }

  /* Preset selector */
  .preset-container {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .preset-select {
    width: 100%;
    padding: 0.5rem 0.75rem;
    font-size: 0.8125rem;
    background: var(--color-bg-content);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    cursor: pointer;
    outline: none;
    transition: border-color var(--duration-fast);
  }

  .preset-select:focus {
    border-color: var(--electric-cyan);
  }

  .preset-description {
    margin: 0;
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    font-style: italic;
    min-height: 1em;
  }

  /* Edge type toggles */
  .edge-type-toggles {
    display: none;
    gap: 0.25rem;
  }

  .edge-type-toggles.active {
    display: flex;
  }

  .edge-toggle-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding: 0.375rem 0.5rem;
    font-size: 0.6875rem;
    background: var(--color-bg-content);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--duration-fast);
    opacity: 0.5;
  }

  .edge-toggle-btn.active {
    opacity: 1;
    color: var(--color-text-secondary);
    border-color: var(--color-border);
  }

  .edge-toggle-btn:hover {
    border-color: var(--color-link);
  }

  .edge-toggle-btn .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot.collaborator { background: #06b6d4; }
  .dot.influenced { background: #a855f7; }
  .dot.mentor { background: #eab308; }

  /* Stats */
  .graph-stats {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    background: var(--color-bg-content);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 0.75rem;
  }

  .stat-item {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }

  .stat-value {
    font-weight: 600;
    color: var(--color-text);
    font-family: 'JetBrains Mono Variable', monospace;
  }

  .stat-label {
    color: var(--color-text-muted);
  }

  .stat-divider {
    color: var(--color-border);
  }

  /* Genre panel */
  .genre-panel {
    display: none;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.75rem;
    background: var(--color-bg-content);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    max-height: 50vh;
    overflow-y: auto;
  }

  .genre-panel.active {
    display: flex;
  }

  .genre-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .group-label {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .genre-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .genre-chip {
    padding: 0.1875rem 0.5rem;
    font-size: 0.6875rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all var(--duration-fast);
    white-space: nowrap;
  }

  .genre-chip:hover {
    border-color: var(--electric-cyan);
    color: var(--color-text);
  }

  .genre-chip.active {
    background: rgba(6, 182, 212, 0.15);
    border-color: var(--electric-cyan);
    color: var(--electric-cyan);
    font-weight: 500;
  }

  .genre-actions {
    display: flex;
    justify-content: flex-end;
  }

  .genre-action-btn {
    padding: 0.25rem 0.5rem;
    font-size: 0.6875rem;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--duration-fast);
  }

  .genre-action-btn:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .graph-controls {
      top: 3.5rem;
      left: 0.5rem;
      right: 0.5rem;
      max-width: none;
    }
  }
</style>
