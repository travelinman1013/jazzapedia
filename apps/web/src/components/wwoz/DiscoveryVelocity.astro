---
/**
 * Discovery Velocity - Server-rendered SVG area chart + rising artists list.
 * Shows new artist discovery rate over time and recently discovered artists.
 */
import { getDatabase } from '../../lib/db';

interface Props {
  locals: App.Locals;
}

const { locals } = Astro.props;
const db = await getDatabase(locals);

interface WeeklyDiscovery {
  week: string;
  count: number;
}

interface RisingArtist {
  display: string;
  firstDate: string;
  totalPlays: number;
  slug: string | null;
}

let weeklyDiscoveries: WeeklyDiscovery[] = [];
let risingArtists: RisingArtist[] = [];
let totalNewArtists = 0;

if (db) {
  try {
    // Get new artists per week
    // Group first_date by week (Monday start)
    const weeklyResult = await db.prepare(`
      SELECT
        date(first_date, 'weekday 1', '-7 days') as week,
        COUNT(*) as count
      FROM wwoz_artist_first_seen
      GROUP BY week
      ORDER BY week
    `).all();
    weeklyDiscoveries = (weeklyResult.results || []) as WeeklyDiscovery[];

    // Rising artists: first seen in last 30 days
    const thirtyDaysAgo = new Date();
    thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
    const cutoff = thirtyDaysAgo.toISOString().slice(0, 10);

    const risingResult = await db.prepare(`
      SELECT artist_display as display, first_date as firstDate, total_plays as totalPlays, artist_slug as slug
      FROM wwoz_artist_first_seen
      WHERE first_date >= ?
      ORDER BY total_plays DESC
      LIMIT 20
    `).bind(cutoff).all();
    risingArtists = (risingResult.results || []) as RisingArtist[];

    // Total unique artists
    const totalResult = await db.prepare('SELECT COUNT(*) as count FROM wwoz_artist_first_seen').first();
    totalNewArtists = (totalResult as { count: number })?.count || 0;
  } catch (error) {
    console.error('Error loading discovery velocity data:', error);
  }
}

// SVG chart dimensions
const chartWidth = 700;
const chartHeight = 180;
const padding = { top: 20, right: 20, bottom: 30, left: 40 };
const innerWidth = chartWidth - padding.left - padding.right;
const innerHeight = chartHeight - padding.top - padding.bottom;

// Compute chart points
const maxCount = weeklyDiscoveries.length > 0
  ? Math.max(...weeklyDiscoveries.map(d => d.count))
  : 1;

const points = weeklyDiscoveries.map((d, i) => ({
  x: padding.left + (i / Math.max(weeklyDiscoveries.length - 1, 1)) * innerWidth,
  y: padding.top + innerHeight - (d.count / maxCount) * innerHeight,
  count: d.count,
  week: d.week,
}));

// Build SVG path for area
const areaPath = points.length > 1
  ? `M${points[0].x},${padding.top + innerHeight} ` +
    points.map(p => `L${p.x},${p.y}`).join(' ') +
    ` L${points[points.length - 1].x},${padding.top + innerHeight} Z`
  : '';

const linePath = points.length > 1
  ? `M` + points.map(p => `${p.x},${p.y}`).join(' L')
  : '';

// Y-axis ticks
const yTicks = [0, Math.round(maxCount / 2), maxCount];

function formatWeek(weekStr: string): string {
  const d = new Date(weekStr + 'T00:00:00Z');
  return `${d.getUTCMonth() + 1}/${d.getUTCDate()}`;
}

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00Z');
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
}
---

<div class="discovery-container">
  {/* Summary stat */}
  <p class="discovery-summary">
    <strong class="discovery-total">{totalNewArtists.toLocaleString()}</strong> unique artists discovered across all tracked days
  </p>

  {/* SVG area chart */}
  {points.length > 1 ? (
    <div class="discovery-chart-wrapper">
      <svg
        viewBox={`0 0 ${chartWidth} ${chartHeight}`}
        class="discovery-chart"
        role="img"
        aria-label="New artists discovered per week"
      >
        {/* Y-axis grid lines */}
        {yTicks.map(tick => {
          const y = padding.top + innerHeight - (tick / maxCount) * innerHeight;
          return (
            <g>
              <line
                x1={padding.left}
                y1={y}
                x2={chartWidth - padding.right}
                y2={y}
                class="chart-grid"
              />
              <text x={padding.left - 8} y={y + 4} text-anchor="end" class="chart-tick-label">
                {tick}
              </text>
            </g>
          );
        })}

        {/* X-axis labels (every 4th week) */}
        {points.map((p, i) => {
          if (i % 4 !== 0 && i !== points.length - 1) return null;
          return (
            <text
              x={p.x}
              y={chartHeight - 5}
              text-anchor="middle"
              class="chart-tick-label"
            >
              {formatWeek(weeklyDiscoveries[i].week)}
            </text>
          );
        })}

        {/* Area fill */}
        <path d={areaPath} class="chart-area" />

        {/* Line */}
        <polyline points={linePath.replace('M', '')} class="chart-line" fill="none" />

        {/* Data points with tooltips */}
        {points.map((p, i) => (
          <circle cx={p.x} cy={p.y} r="3" class="chart-point">
            <title>{`Week of ${formatWeek(weeklyDiscoveries[i].week)}: ${p.count} new artists`}</title>
          </circle>
        ))}
      </svg>
    </div>
  ) : (
    <p class="text-wiki-text-muted">Not enough data for chart.</p>
  )}

  {/* Rising Artists */}
  {risingArtists.length > 0 && (
    <div class="rising-section">
      <h3 class="rising-title">Rising Artists</h3>
      <p class="rising-subtitle">First heard on WWOZ in the last 30 days</p>

      <div class="rising-list">
        {risingArtists.map((artist) => (
          <div class="rising-artist">
            <div class="rising-info">
              {artist.slug ? (
                <a href={`/artists/${artist.slug}`} class="rising-name wiki-link">
                  {artist.display}
                </a>
              ) : (
                <span class="rising-name">{artist.display}</span>
              )}
              <span class="rising-meta">
                First played {formatDate(artist.firstDate)}
              </span>
            </div>
            <div class="rising-stats">
              <span class="rising-plays">{artist.totalPlays} plays</span>
              {artist.slug ? (
                <span class="rising-badge rising-badge--wiki">In Wiki</span>
              ) : (
                <span class="rising-badge rising-badge--new">New</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  )}
</div>

<style>
  .discovery-container {
    margin-top: 1rem;
  }

  .discovery-summary {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .discovery-total {
    font-family: 'Playfair Display Variable', Georgia, serif;
    font-size: 1.25rem;
    color: var(--jazz-amber);
  }

  .discovery-chart-wrapper {
    background: var(--color-bg);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .discovery-chart {
    width: 100%;
    height: auto;
  }

  .chart-grid {
    stroke: var(--color-border-light);
    stroke-width: 0.5;
    stroke-dasharray: 4 4;
  }

  .chart-tick-label {
    font-size: 9px;
    fill: var(--color-text-muted);
    font-family: 'JetBrains Mono Variable', monospace;
  }

  .chart-area {
    fill: var(--jazz-amber);
    opacity: 0.15;
  }

  .chart-line {
    stroke: var(--jazz-amber);
    stroke-width: 2;
    stroke-linejoin: round;
  }

  .chart-point {
    fill: var(--jazz-amber);
    transition: r var(--duration-fast) var(--ease-smooth);
  }

  .chart-point:hover {
    r: 5;
    fill: var(--electric-cyan);
  }

  /* Rising artists */
  .rising-section {
    margin-top: 0.5rem;
  }

  .rising-title {
    font-family: 'Playfair Display Variable', Georgia, serif;
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-text-heading);
    margin: 0 0 0.25rem;
  }

  .rising-subtitle {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
  }

  .rising-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .rising-artist {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-md);
    transition: border-color var(--duration-fast) var(--ease-smooth);
  }

  .rising-artist:hover {
    border-color: var(--color-link);
  }

  .rising-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .rising-name {
    font-weight: 500;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .rising-name.wiki-link {
    color: var(--color-link);
    text-decoration: none;
  }

  .rising-name.wiki-link:hover {
    text-decoration: underline;
  }

  .rising-meta {
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .rising-stats {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .rising-plays {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .rising-badge {
    font-size: 0.6rem;
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  .rising-badge--wiki {
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .rising-badge--new {
    background: rgba(212, 162, 84, 0.15);
    color: var(--jazz-amber);
    border: 1px solid rgba(212, 162, 84, 0.3);
  }

  /* Dark mode */
  :global([data-mode="dark"]) .discovery-chart-wrapper,
  :global([data-mode="dark"]) .rising-artist {
    background: var(--jazz-smoke);
  }
</style>
