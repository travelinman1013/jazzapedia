---
/**
 * SoundsLike Component - Audio Similarity Section
 * Shows top 5 artists with similar audio DNA in the infobox
 */

interface SimilarArtist {
  slug: string;
  title: string;
  image_filename?: string | null;
  score: number;
  imageUrl?: string;
}

interface Props {
  similarArtists: SimilarArtist[];
}

const { similarArtists } = Astro.props;
if (!similarArtists || similarArtists.length === 0) return;
---

<div class="sounds-like-section">
  <div class="sounds-like-header">
    <svg class="sounds-like-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M9 18V5l12-2v13" stroke-linecap="round" stroke-linejoin="round" />
      <circle cx="6" cy="18" r="3" />
      <circle cx="18" cy="16" r="3" />
    </svg>
    <span>Similar DNA</span>
  </div>
  <div class="sounds-like-list">
    {similarArtists.map(artist => (
      <a href={`/artists/${artist.slug}`} class="similar-artist">
        <div class="similar-thumb">
          {artist.imageUrl ? (
            <img src={artist.imageUrl} alt="" class="similar-img" loading="lazy" />
          ) : (
            <span class="similar-placeholder">&#9835;</span>
          )}
        </div>
        <span class="similar-name">{artist.title}</span>
        <span class="similar-score">{Math.round(artist.score * 100)}%</span>
      </a>
    ))}
  </div>
</div>

<style>
  .sounds-like-section {
    padding: 0.75rem;
    border-top: 1px solid var(--color-border-light);
  }

  .sounds-like-header {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--jazz-amber);
    margin-bottom: 0.5rem;
  }

  .sounds-like-icon {
    width: 1rem;
    height: 1rem;
  }

  .sounds-like-list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .similar-artist {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem;
    border-radius: var(--radius-md, 0.375rem);
    text-decoration: none;
    color: var(--color-text);
    transition: background 0.15s ease;
  }

  .similar-artist:hover {
    background: var(--color-accent-light);
  }

  .similar-thumb {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--color-bg-nav);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .similar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .similar-placeholder {
    font-size: 0.6rem;
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  .similar-name {
    flex: 1;
    font-size: 0.8rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }

  .similar-score {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--jazz-amber);
    flex-shrink: 0;
    padding: 0.1rem 0.375rem;
    background: rgba(212, 162, 84, 0.12);
    border-radius: 9999px;
  }
</style>
